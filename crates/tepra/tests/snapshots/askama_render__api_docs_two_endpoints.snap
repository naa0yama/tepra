      <main id="main" tabindex="-1" class="flex-1 p-4">
        
  

  <h1 class="text-2xl font-bold mb-4">API Reference</h1>

  
    <div class="join join-vertical w-full">
      
        <div class="collapse collapse-arrow join-item border border-base-300 bg-base-100">
          <input type="checkbox" aria-label="GET /api/printer" />
          <div class="collapse-title flex flex-wrap items-center gap-3">
            <span class="badge badge-outline badge-info">
              GET
            </span>
            <code class="font-mono text-sm">/api/printer</code>
            <span class="opacity-70 text-sm">List printers</span>
            
          </div>
          <div class="collapse-content flex flex-col gap-3">
            
  

            
  

            
  

            
            
              <details>
                <summary class="cursor-pointer text-xs font-semibold opacity-70">Raw JSON schema (response)</summary>
                <pre class="bg-base-200 p-2 rounded text-xs overflow-x-auto mt-1">{&#34;type&#34;:&#34;array&#34;}</pre>
              </details>
            
            
              <details>
                <summary class="cursor-pointer text-xs font-semibold opacity-70">Sample response</summary>
                <pre class="bg-base-200 p-2 rounded text-xs overflow-x-auto mt-1">[]</pre>
              </details>
            
            
<div class="mt-2 border-t border-base-300 pt-3">
  <h3 class="font-semibold text-sm mb-2">Try it out</h3>
  <form
    class="try-it-out-form flex flex-col gap-2"
    data-method="GET"
    data-path="/api/printer"
    
    
    hx-get="/api/printer"
    hx-target="#try-it-out-result-1"
    hx-swap="none"
    
  >
    
    
    
      <button type="submit" class="btn btn-primary btn-sm self-start">Execute</button>
    
  </form>
  <pre id="try-it-out-result-1" class="bg-base-200 p-2 rounded text-xs overflow-x-auto mt-2"></pre>
</div>

          </div>
        </div>
      
        <div class="collapse collapse-arrow join-item border border-base-300 bg-base-100">
          <input type="checkbox" aria-label="POST /api/printer/print/{name}" />
          <div class="collapse-title flex flex-wrap items-center gap-3">
            <span class="badge badge-outline badge-warning">
              POST
            </span>
            <code class="font-mono text-sm">/api/printer/print/{name}</code>
            <span class="opacity-70 text-sm">Print a label</span>
            
              <span class="badge badge-outline badge-error badge-sm">destructive</span>
            
          </div>
          <div class="collapse-content flex flex-col gap-3">
            
  

            
  

            
  

            
              <details>
                <summary class="cursor-pointer text-xs font-semibold opacity-70">Raw JSON schema (request)</summary>
                <pre class="bg-base-200 p-2 rounded text-xs overflow-x-auto mt-1">{&#34;type&#34;:&#34;object&#34;}</pre>
              </details>
            
            
            
            
<div class="mt-2 border-t border-base-300 pt-3">
  <h3 class="font-semibold text-sm mb-2">Try it out</h3>
  <form
    class="try-it-out-form flex flex-col gap-2"
    data-method="POST"
    data-path="/api/printer/print/{name}"
    
    data-destructive-form
    
    
    data-json-body-form
    
  >
    
      <label class="input input-sm input-bordered flex items-center gap-2">
        <span class="font-mono">name</span>
        
          <select name="name" data-path-param="name" data-printer-select required class="grow">
            <option value="" disabled selected>Loading printers…</option>
          </select>
        
      </label>
    
    
      <textarea
        name="body"
        data-json-body
        class="textarea textarea-bordered textarea-sm font-mono"
        rows="4"
        placeholder="JSON request body"
      ></textarea>
    
    
      <button type="button" class="btn btn-error btn-sm self-start" data-destructive-trigger>Execute</button>
    
  </form>
  <pre id="try-it-out-result-2" class="bg-base-200 p-2 rounded text-xs overflow-x-auto mt-2"></pre>
</div>

          </div>
        </div>
      
    </div>

    <dialog id="destructive-confirm-modal" class="modal">
      <div class="modal-box">
        <h3 class="font-bold text-lg">Confirm destructive action</h3>
        <p class="py-2">
          Executing <code id="destructive-confirm-target"></code> causes a
          physical printer action (printing / tape feed). Continue?
        </p>
        <div class="modal-action">
          <button type="button" class="btn" id="destructive-confirm-cancel">Cancel</button>
          <button type="button" class="btn btn-error" id="destructive-confirm-confirm">Confirm</button>
        </div>
      </div>
    </dialog>
  

  <script>
    (() => {
      // WHY-NOT: server-side printer <option> render — api_docs handler stays
      // stateless (no client dependency); populate the {name} dropdown via a
      // client-side fetch of the already-instrumented /api/printer route instead.
      fetch("/api/printer")
        .then((res) => {
          if (!res.ok) {
            throw new Error(`HTTP ${res.status}`);
          }
          return res.json();
        })
        .then((printers) => {
          if (!Array.isArray(printers) || printers.length === 0) {
            throw new Error("empty printer list");
          }
          document.querySelectorAll("[data-printer-select]").forEach((select) => {
            select.innerHTML = "";
            const placeholder = document.createElement("option");
            placeholder.value = "";
            placeholder.disabled = true;
            placeholder.selected = true;
            placeholder.textContent = "Select printer…";
            select.appendChild(placeholder);
            printers.forEach((printer) => {
              const option = document.createElement("option");
              option.value = printer.printerName;
              option.textContent = printer.printerName;
              select.appendChild(option);
            });
          });
        })
        .catch(() => {
          // Degrade to a plain text input: keep data-path-param so the
          // existing path-substitution handlers below need no changes.
          document.querySelectorAll("[data-printer-select]").forEach((select) => {
            const input = document.createElement("input");
            input.type = "text";
            input.name = select.name;
            input.required = true;
            input.className = select.className;
            input.dataset.pathParam = select.dataset.pathParam;
            select.replaceWith(input);
          });
        });

      // Path param substitution for `hx-get` forms (mechanism 2): htmx does
      // not fill `{name}` placeholders from form inputs, so replace them
      // here and drop the matching entries from the outgoing parameters —
      // otherwise they would also be sent as a duplicate query string.
      document.body.addEventListener("htmx:configRequest", (evt) => {
        const form = evt.detail.elt;
        if (!(form instanceof HTMLFormElement) || !form.classList.contains("try-it-out-form")) {
          return;
        }
        form.querySelectorAll("[data-path-param]").forEach((input) => {
          const name = input.dataset.pathParam;
          evt.detail.path = evt.detail.path.replace(`{${name}}`, encodeURIComponent(input.value));
          delete evt.detail.parameters[name];
        });
      });

      // WHY-NOT: hx-swap — inserts raw JSON as HTML, no pretty-print, breaks on '<'/'>'
      document.body.addEventListener("htmx:beforeSwap", (evt) => {
        const form = evt.detail.requestConfig?.elt;
        if (!(form instanceof HTMLFormElement) || !form.classList.contains("try-it-out-form")) {
          return;
        }
        evt.detail.shouldSwap = false;
        renderResult(evt.detail.target, evt.detail.xhr.responseText);
      });

      // POST forms carrying a JSON request body (mechanism 3): htmx has no
      // built-in JSON body encoding, so these forms skip hx-post entirely
      // and are submitted by hand via fetch().
      document.body.querySelectorAll("form.try-it-out-form[data-json-body-form]").forEach((form) => {
        form.addEventListener("submit", (evt) => {
          evt.preventDefault();
          let path = form.dataset.path;
          form.querySelectorAll("[data-path-param]").forEach((input) => {
            path = path.replace(`{${input.dataset.pathParam}}`, encodeURIComponent(input.value));
          });
          const bodyField = form.querySelector("[data-json-body]");
          const result = form.nextElementSibling;
          fetch(path, {
            method: form.dataset.method,
            headers: { "Content-Type": "application/json" },
            body: bodyField.value || "{}",
          })
            .then((res) => res.text())
            .then((text) => renderResult(result, text))
            .catch((err) => renderResult(result, String(err)));
        });
      });

      function renderResult(target, text) {
        if (!(target instanceof HTMLElement)) {
          return;
        }
        try {
          target.textContent = JSON.stringify(JSON.parse(text), null, 2);
        } catch {
          target.textContent = text;
        }
      }

      // Destructive endpoints (print / tapefeed / job_control) route the
      // Execute click through a confirm modal instead of submitting the
      // form directly (the button's type attribute is button, not submit).
      let pendingDestructiveForm = null;
      let destructiveConfirmed = false;
      const modal = document.getElementById("destructive-confirm-modal");
      const confirmTarget = document.getElementById("destructive-confirm-target");

      // WHY-NOT: click-only gate — a single required text field submits
      // natively on Enter, bypassing the click-based [data-destructive-trigger]
      // listener below entirely. Guard the "submit" event itself, in capture
      // phase so this fires before htmx's own form-level submit listener and
      // the json-body-form handler above (both of which stopPropagation
      // cannot reach once we've stopped it here).
      document.body.addEventListener("submit", (evt) => {
        const form = evt.target;
        if (!(form instanceof HTMLFormElement) || form.dataset.destructiveForm === undefined) {
          return;
        }
        if (destructiveConfirmed) {
          destructiveConfirmed = false;
          return;
        }
        evt.preventDefault();
        evt.stopPropagation();
        pendingDestructiveForm = form;
        if (confirmTarget) {
          confirmTarget.textContent = `${form.dataset.method} ${form.dataset.path}`;
        }
        modal?.showModal();
      }, true);

      document.body.addEventListener("click", (evt) => {
        const trigger = evt.target.closest("[data-destructive-trigger]");
        if (!trigger) {
          return;
        }
        const form = trigger.closest("form.try-it-out-form");
        if (!form) {
          return;
        }
        pendingDestructiveForm = form;
        if (confirmTarget) {
          confirmTarget.textContent = `${form.dataset.method} ${form.dataset.path}`;
        }
        modal?.showModal();
      });

      document.getElementById("destructive-confirm-confirm")?.addEventListener("click", () => {
        modal?.close();
        // requestSubmit() re-dispatches a native "submit" event, which the
        // capturing guard above intercepts again — set destructiveConfirmed
        // so this one re-dispatch is let through to the existing htmx /
        // fetch handlers instead of re-opening the modal.
        destructiveConfirmed = true;
        pendingDestructiveForm?.requestSubmit();
        // requestSubmit() skips the "submit" event entirely when the form
        // fails interactive constraint validation, so the guard above never
        // runs and never resets the flag. Force-clear here so a failed
        // validation attempt cannot leave the gate open for a later submit.
        destructiveConfirmed = false;
        pendingDestructiveForm = null;
      });

      document.getElementById("destructive-confirm-cancel")?.addEventListener("click", () => {
        modal?.close();
        pendingDestructiveForm = null;
      });
    })();
  </script>

      </main>
    </div>

    <div class="drawer-side">
      <label for="drawer-toggle" aria-label="Close menu" class="drawer-overlay"></label>
      
<div class="bg-base-100 border-r border-base-300 min-h-full w-64 flex flex-col">
  
